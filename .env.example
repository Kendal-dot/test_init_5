# ============================================================
# Lokal mГ¶testranskriberingsplattform вҖ“ miljГ¶variabler
# Kopiera denna fil till .env och anpassa vГӨrdena
# ============================================================

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# --- Lagring ---
# Absolut sГ¶kvГӨg inuti containern (mappas via Docker-volymer)
STORAGE_DIR=/app/storage
UPLOADS_DIR=/app/storage/uploads
MODELS_CACHE_DIR=/app/storage/models_cache

# --- Databas ---
DATABASE_URL=sqlite:////app/storage/db/transcriber.db

# --- Transkriberingspipeline ---
# TillgГӨngliga storlekar: tiny, base, small, medium, large
TRANSCRIPTION_MODEL=KBLab/kb-whisper-small

# VAD-backend: silero (ingen autentisering) eller pyannote (krГӨver HF-token)
VAD_BACKEND=silero

# Hugging Face-token вҖ“ krГӨvs om VAD_BACKEND=pyannote eller DIARIZATION_ENABLED=true
# Acceptera villkoren fГ¶r pyannote/speaker-diarization-3.1 pГҘ HuggingFace fГ¶rst
HF_TOKEN=

# SГӨtt till true fГ¶r att aktivera talaridentifiering (krГӨver HF_TOKEN)
DIARIZATION_ENABLED=false

# Antal talare (0 = automatisk detektering)
MAX_SPEAKERS=0
MIN_SPEAKERS=1

# --- CORS ---
# Kommaseparerade origins tillГҘtna att nГҘ API:t
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Jobbhantering ---
# Max antal parallella transkriberingsjobb (rekommenderat: 1 med GPU)
MAX_CONCURRENT_JOBS=1
